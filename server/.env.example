# ============================================================
# eCabinet Server — cấu hình môi trường
# ============================================================

# Cổng API (mặc định 3000)
PORT=3000

# KHÓA BÍ MẬT ký JWT — BẮT BUỘC đổi khi triển khai thật
JWT_SECRET=change-me-in-production

# Thời hạn access token (giây) — mặc định 1 giờ (GĐ4: gia hạn bằng refresh token)
JWT_TTL=3600

# Thời hạn refresh token (giây) — mặc định 7 ngày; xoay vòng mỗi lần dùng
REFRESH_TTL_SEC=604800

# Rate-limit (GĐ4)
RATE_LIMIT_MAX=300          # yêu cầu / IP / cửa sổ
RATE_LIMIT_WINDOW_MS=60000  # cửa sổ 60 giây
LOGIN_RATE_MAX=10           # lần đăng nhập / IP + tài khoản
LOGIN_RATE_WINDOW_MS=900000 # cửa sổ 15 phút

# Kết nối PostgreSQL. Nếu KHÔNG đặt, server tự chạy bằng PGlite
# (Postgres nhúng, lưu tại PGLITE_DIR) — tiện dev/demo không cần cài DB.
# DATABASE_URL=postgres://ecabinet:ecabinet@localhost:5432/ecabinet

# Thư mục dữ liệu PGlite (chỉ dùng khi không có DATABASE_URL)
PGLITE_DIR=./data/ecabinet-db

# CORS origin cho phép (mặc định *; khi chạy sau nginx proxy cùng origin thì không cần)
# CORS_ORIGIN=https://ecabinet.example.gov.vn
