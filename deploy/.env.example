# ============================================================
# eCabinet — Cấu hình triển khai PILOT (mức 1)
# Sao chép file này thành deploy/.env rồi chỉnh; hoặc để pilot.sh
# tự sinh secret ngẫu nhiên (khuyến nghị). TUYỆT ĐỐI không commit .env.
# ============================================================

# --- Tên miền phục vụ HTTPS ---
# Đặt tên miền trỏ về IP máy chủ (bản ghi A) để Caddy tự xin chứng chỉ Let's Encrypt.
# Nếu chạy mạng nội bộ/không có Internet: đặt TLS_MODE=internal và DOMAIN = hostname/IP.
DOMAIN=ecabinet.example.gov.vn

# Email nhận cảnh báo gia hạn chứng chỉ (Let's Encrypt)
ACME_EMAIL=cntt@example.gov.vn

# Chế độ TLS: letsencrypt (mặc định, cần domain công khai) | internal (tự ký, LAN/air-gapped)
TLS_MODE=letsencrypt
# pilot.sh sẽ tự đặt CADDYFILE theo TLS_MODE. Không cần sửa dòng dưới thủ công.
CADDYFILE=./Caddyfile

# --- Bí mật (pilot.sh tự sinh nếu còn để placeholder) ---
JWT_SECRET=__CHANGE_ME_JWT__
DB_PASSWORD=__CHANGE_ME_DB__

# --- Vòng đời token ---
JWT_TTL=3600            # access token 1 giờ
REFRESH_TTL_SEC=604800  # refresh token 7 ngày

# --- Giới hạn tần suất ---
RATE_LIMIT_MAX=300
LOGIN_RATE_MAX=10

# --- Sao lưu ---
BACKUP_KEEP=30          # số bản sao lưu giữ lại (mỗi ngày 1 bản ~ 1 tháng)

# --- Họp trực tuyến WebRTC (LiveKit) ---
# GATED: để TRỐNG cả 3 biến -> app dùng giao diện MÔ PHỎNG (không cần media server).
# Điền để bật họp thật (âm thanh/hình ảnh/chia sẻ màn hình).
#   Cách nhanh nhất: LiveKit Cloud (https://cloud.livekit.io) — tạo project, lấy
#   URL + API key/secret; KHÔNG phải tự lo cổng UDP/TURN/TLS.
#   Tự host: xem README (mục "Họp trực tuyến WebRTC") — cần mở dải cổng UDP + TURN.
# LIVEKIT_URL là URL WSS trình duyệt kết nối; API_KEY/API_SECRET để BACKEND mint token.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
